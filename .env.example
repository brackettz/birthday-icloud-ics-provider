# Apple ID (email address)
ICLOUD_USERNAME=your@apple.id

# App-specific password (not your regular Apple ID password!)
# Create one at: https://appleid.apple.com -> Sign-In and Security -> App-Specific Passwords
ICLOUD_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional secret token in the URL: /birthdays/YOUR_TOKEN.ics
# Leave empty for no protection (URL will be: /birthdays.ics)
SECRET_TOKEN=

# Cache duration in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600

# Port (default: 5000)
PORT=5000
